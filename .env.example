# ---- BuyCoin (Extop) widget ----
# data-token for the embedded widget (the "API Token" from your BuyCoin widget).
# Widget: Bassil Lama (8e98d0f2-dace-459a-90b2-c86bd87de5a8)
BUYCOIN_WIDGET_TOKEN=96e545e0399d2b453a25f19038f6ef0e373d5816de59dd2bc900f32ab0a9407d

# Where the embeddable widget script is served from. Usually leave as-is.
BUYCOIN_EXCHANGER_URL=https://buycoin.online/x/calc/exchanger.js

# Default exchange pair shown in the widget.
# FROM = what the customer pays with (fiat), TO = crypto settled to the wallet.
# TO must match the currency of the destination (e.g. NOWPayments) address.
WIDGET_CURRENCY_FROM=EUR
WIDGET_CURRENCY_TO=USDT

WIDGET_LOCALE=en
WIDGET_LAYOUT=vertical
WIDGET_THEME=light

# Only auto-run the payment automation for traffic from this origin substring.
# Set to "*" (or empty) to disable the referrer check (useful for local testing).
ALLOWED_REFERRER=peptides
