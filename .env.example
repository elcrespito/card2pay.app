# ---------------------------------------------------------------------------
# Card2pay platform — environment variables
# ---------------------------------------------------------------------------

# Public base URL of this deployment (used for IPN callback + share links).
APP_URL=https://card2pay.app

# Postgres connection string.
DATABASE_URL=postgresql://card2pay:card2pay@db:5432/card2pay?schema=public

# Secret used to sign session cookies (generate a long random string).
SESSION_SECRET=change-me-to-a-long-random-string

# First admin account, created/updated by the seed script on deploy.
ADMIN_EMAIL=admin@card2pay.app
ADMIN_PASSWORD=ChangeMe!2026
ADMIN_NAME=Card2pay Admin

# New merchants need admin approval before they can create links.
REQUIRE_APPROVAL=true

# ---- NOWPayments -----------------------------------------------------------
# Dashboard -> Settings -> API keys
NOWPAYMENTS_API_KEY=
# Dashboard -> Store Settings -> IPN. Set the IPN callback URL there to:
#   https://card2pay.app/api/webhooks/nowpayments
NOWPAYMENTS_IPN_SECRET=
# Crypto NOWPayments generates a deposit address for. Must match the widget network.
NOWPAYMENTS_PAY_CURRENCY=usdttrc20
# Fiat currency the link amount is priced in when creating the payment.
NOWPAYMENTS_PRICE_CURRENCY=usd
NOWPAYMENTS_FIXED_RATE=true
NOWPAYMENTS_FEE_PAID_BY_USER=false

# ---- BuyCoin widget (embedded checkout) ------------------------------------
BUYCOIN_WIDGET_TOKEN=96e545e0399d2b453a25f19038f6ef0e373d5816de59dd2bc900f32ab0a9407d
BUYCOIN_EXCHANGER_URL=https://buycoin.online/x/calc/exchanger.js
WIDGET_CURRENCY_FROM=
WIDGET_CURRENCY_TO=
WIDGET_LOCALE=en
WIDGET_LAYOUT=vertical
WIDGET_THEME=
# Origin allowed to auto-run the widget automation. "*" = always on.
ALLOWED_REFERRER=*
